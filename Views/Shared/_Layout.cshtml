<!DOCTYPE html>
<html class="h-full" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    <script>
        if (localStorage.getItem('template-theme') === 'dark' || (!('template-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    @Html.Vite("Styles/app.css", "Scripts/app.js")
</head>
<body class="theme-fade min-h-screen bg-slate-50 text-slate-900 transition-colors duration-200 dark:bg-slate-950 dark:text-slate-100">
    <nav class="border-b border-slate-200 bg-slate-900 text-white dark:border-slate-800 dark:bg-slate-900">
        <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between px-6 py-4">

            @Html.ActionLink(
                "Application name",
                "Index",
                "Home",
                new { area = "" },
                new { @class = "text-lg font-semibold text-white transition-colors hover:text-amber-300" }
            )

            <div class="flex items-center gap-3 md:order-3">
                <button id="theme-toggle"
                        type="button"
                        class="rounded-md border border-slate-400/40 p-2 text-slate-100 transition hover:bg-white/10"
                        aria-label="Toggle dark mode">
                    <span id="theme-toggle-icon" aria-hidden="true">🌙</span>
                </button>
                <button id="mobile-menu-toggle"
                        type="button"
                        class="rounded-md border border-slate-500/50 p-2 text-slate-100 transition hover:bg-white/10 md:hidden"
                        aria-controls="site-menu"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span id="menu-toggle-icon" aria-hidden="true">☰</span>
                </button>
            </div>

            <div id="site-menu" class="hidden w-full pt-4 md:block md:w-auto md:flex-1 md:pt-0 md:pl-8">
                <ul class="flex flex-col gap-3 border-t border-slate-700/60 pt-4 md:flex-row md:items-center md:gap-6 md:border-0 md:pt-0">
                    <li>@Html.ActionLink("Home", "Index", "Home", new { area = "" }, new { @class = "block text-sm font-medium text-slate-200 transition-colors hover:text-white" })</li>
                    <li>@Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "block text-sm font-medium text-slate-200 transition-colors hover:text-white" })</li>
                    <li>@Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "block text-sm font-medium text-slate-200 transition-colors hover:text-white" })</li>
                </ul>
            </div>

        </div>
    </nav>
    <div class="mx-auto max-w-6xl px-6 py-8">
        @RenderBody()
        <footer class="mt-10 border-t border-slate-200 pt-6 dark:border-slate-800">
            <p class="text-sm text-slate-500 dark:text-slate-400">&copy; @DateTime.Now.Year - My ASP.NET Application</p>
        </footer>
    </div>

    @RenderSection("scripts", required: false)
</body>
</html>
