<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Html.Vite("Styles/app.css", "Scripts/app.js")
</head>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <nav class="border-b border-slate-200 bg-slate-900 text-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
            @Html.ActionLink(
                "Application name",
                "Index",
                "Home",
                new { area = "" },
                new { @class = "text-lg font-semibold text-white transition-colors hover:text-amber-300" }
            )
            <ul class="flex gap-6">
                <li>@Html.ActionLink("Home", "Index", "Home", new { area = "" }, new { @class = "text-sm font-medium text-slate-200 transition-colors hover:text-white" })</li>
                <li>@Html.ActionLink("About", "About", "Home", new { area = "" }, new { @class = "text-sm font-medium text-slate-200 transition-colors hover:text-white" })</li>
                <li>@Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "text-sm font-medium text-slate-200 transition-colors hover:text-white" })</li>
            </ul>
        </div>
    </nav>
    <div class="mx-auto max-w-6xl px-6 py-8">
        @RenderBody()
        <footer class="mt-10 border-t border-slate-200 pt-6">
            <p class="text-sm text-slate-500">&copy; @DateTime.Now.Year - My ASP.NET Application</p>
        </footer>
    </div>

    @RenderSection("scripts", required: false)
</body>
</html>
