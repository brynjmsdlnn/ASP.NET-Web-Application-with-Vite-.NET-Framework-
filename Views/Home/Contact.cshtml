@{
    ViewBag.Title = "Contact";
}
<main aria-labelledby="title" class="space-y-4">
    <section class="space-y-2" aria-labelledby="title">
        <h2 id="title" class="text-3xl font-bold text-slate-900 dark:text-slate-100">@ViewBag.Title.</h2>
        <p class="text-lg leading-relaxed font-semibold text-slate-700 dark:text-slate-300">
            Get in touch with the creator of this template.
        </p>
        <div class="grid gap-4 md:grid-cols-2">
            <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
                <h4 class="mb-2 text-lg font-semibold text-slate-900 dark:text-slate-100">Project details and source</h4>
                <p class="mb-3 text-sm text-slate-600 dark:text-slate-400">
                    For repository details and source code, visit:
                </p>
                <a
                    href="https://github.com/brynjmsdlnn/ASP.NET-Web-Application-with-Vite-.NET-Framework-"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-800 dark:bg-slate-100 dark:text-slate-900 dark:hover:bg-white">
                    View on GitHub
                </a>
            </article>

            <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
                <h4 class="mb-2 text-lg font-semibold text-slate-900 dark:text-slate-100">Contact</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                    For questions or collaboration, email:
                    <a href="mailto:bryanjamesdalanon@gmail.com" class="text-blue-700 underline hover:text-blue-900 dark:text-blue-300">bryanjamesdalanon@gmail.com</a>
                </p>
            </article>
        </div>
    </section>
</main>