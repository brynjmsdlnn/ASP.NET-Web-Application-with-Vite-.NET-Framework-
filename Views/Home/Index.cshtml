@{
    ViewBag.Title = "Template Home";
}

<main class="space-y-8">
    <section class="space-y-4" aria-labelledby="templateTitle">
        <h1 id="templateTitle" class="text-3xl font-bold text-slate-900 dark:text-slate-100">Welcome to the ASP.NET + Vite Template</h1>
        <p class="text-lg leading-relaxed text-slate-700 dark:text-slate-300">
            This is a starter template for building classic ASP.NET MVC/Web API applications on <strong>.NET Framework 4.8.1</strong> while using modern frontend tooling.
            It includes <strong>Vite 8.0.1</strong> for asset bundling and <strong>Tailwind CSS 4.2</strong> for styling.
        </p>
        <p class="text-sm text-slate-600 dark:text-slate-400">You can use this project as a base for internal admin tools, enterprise portals, or any MVC-based .NET Framework app.</p>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <h2 class="mb-2 text-xl font-semibold text-slate-900 dark:text-slate-100">What this includes</h2>
            <ul class="list-inside list-disc space-y-1 text-sm text-slate-700 dark:text-slate-300">
                <li>.NET Framework 4.8.1 MVC + Web API project structure</li>
                <li>Vite integration via <code>@Html.Raw("@Html.Vite(...)")</code></li>
                <li>Tailwind CSS pipeline and utility-first styling</li>
                <li>Build output folder: <code>wwwroot/dist</code></li>
            </ul>
        </article>

        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <h2 class="mb-2 text-xl font-semibold text-slate-900 dark:text-slate-100">Quick start</h2>
            <ol class="list-inside list-decimal space-y-1 text-sm text-slate-700 dark:text-slate-300">
                <li>Run <code>npm install</code></li>
                <li>Run <code>npm run build</code></li>
                <li>Press F5 in Visual Studio</li>
            </ol>
        </article>

        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <h2 class="mb-2 text-xl font-semibold text-slate-900 dark:text-slate-100">Great template candidates</h2>
            <p class="text-sm text-slate-700 dark:text-slate-300">
                This starter is ideal when you want ASP.NET stability and modern frontend performance together, especially for existing teams moving legacy MVC apps toward current tooling.
            </p>
        </article>
    </section>

    <section class="rounded-xl border border-blue-200 bg-blue-50 p-4 dark:border-blue-900 dark:bg-blue-950">
        <p class="text-sm text-blue-900 dark:text-blue-200">
            To customize this landing page, edit <code>Views/Home/Index.cshtml</code>.
            To customize styles, update <code>Styles/app.css</code> and keep your scripts in <code>Scripts/app.js</code>.
        </p>
    </section>
</main>